<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IronCore | Loja</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black shadow border-bottom border-warning">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">IRON<span class="text-warning">CORE</span></a>
        </div>
    </nav>

    <div class="container py-5">
        <h2 class="fw-bold mb-4">Equipamentos de Elite</h2>
        <div class="row g-4 text-dark">
            
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow">
                    <img src="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?auto=format&fit=crop&w=500&q=80" class="card-img-top" alt="Halteres">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold">Kit de Halteres Pro</h5>
                        <p class="text-muted flex-grow-1">Pares de 5kg a 25kg em aço revestido.</p>
                        <h6 class="text-danger fw-bold fs-5">R$ 1.200,00</h6>
                        
                        <form action="/salvar" method="POST" class="mt-3">
                            <input type="hidden" name="produto" value="Kit de Halteres Pro">
                            <input type="hidden" name="preco" value="1200.00">
                            <button type="submit" class="btn btn-warning w-100 fw-bold">Registrar Interesse</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQAmsHlzWluOwV8uw-lJ3asV30yeQROZXn-dw&s" class="card-img-top" alt="Banco">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold">Banco Regulável X-Heavy</h5>
                        <p class="text-muted flex-grow-1">Suporta até 300kg com 6 ângulos de inclinação.</p>
                        <h6 class="text-danger fw-bold fs-5">R$ 850,00</h6>
                        
                        <form action="/salvar" method="POST" class="mt-3">
                            <input type="hidden" name="produto" value="Banco Regulável X-Heavy">
                            <input type="hidden" name="preco" value="850.00">
                            <button type="submit" class="btn btn-warning w-100 fw-bold">Registrar Interesse</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow">
                    <img src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?auto=format&fit=crop&w=500&q=80" class="card-img-top" alt="Esteira">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold">Esteira Iron Run 500</h5>
                        <p class="text-muted flex-grow-1">Motor de 3HP e monitor de frequência cardíaca.</p>
                        <h6 class="text-danger fw-bold fs-5">R$ 4.500,00</h6>
                        
                        <form action="/salvar" method="POST" class="mt-3">
                            <input type="hidden" name="produto" value="Esteira Iron Run 500">
                            <input type="hidden" name="preco" value="4500.00">
                            <button type="submit" class="btn btn-warning w-100 fw-bold">Registrar Interesse</button>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>