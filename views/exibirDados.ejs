<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>IronCore | Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-dark bg-black border-bottom border-warning mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">IRON<span class="text-warning">CORE</span></a>
            <a href="/" class="btn btn-outline-warning btn-sm">Voltar</a>
        </div>
    </nav>

    <div class="container">
        <h2 class="text-warning fw-bold mb-4">Mensagens Recebidas (QG)</h2>
        
        <div class="table-responsive">
            <table class="table table-dark table-hover border-secondary shadow">
                <thead class="table-warning text-dark">
                    <tr>
                        <th>Guerreiro(a)</th>
                        <th>E-mail</th>
                        <th>Mensagem de Treino</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (contatos.length > 0) { %>
                        <% contatos.forEach(c => { %>
                            <tr>
                                <td class="fw-bold"><%= c.nome %></td>
                                <td><%= c.email %></td>
                                <td><%= c.mensagem %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" class="text-center text-muted">Nenhum dado no banco de dados.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
