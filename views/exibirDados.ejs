<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>IronCore | Registros</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-dark bg-black border-bottom border-warning mb-4">
        <div class="container"><a class="navbar-brand fw-bold" href="/">IRONCORE</a></div>
    </nav>

    <div class="container">
        <h2 class="text-warning fw-bold mb-4">MENSAGENS DO QG</h2>
        
        <div class="table-responsive">
            <table class="table table-dark table-striped border-secondary shadow">
                <thead class="table-warning text-dark">
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Mensagem</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (contatos.length > 0) { %>
                        <% contatos.forEach(item => { %>
                            <tr>
                                <td><%= item.nome %></td>
                                <td><%= item.email %></td>
                                <td><%= item.mensagem %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="3" class="text-center text-muted">Nenhum registro no sistema.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        <a href="/" class="btn btn-warning mt-3">Voltar ao Início</a>
    </div>
</body>
</html>
