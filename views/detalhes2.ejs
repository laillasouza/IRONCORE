<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IronCore | Banco</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">
    <nav class="navbar navbar-dark bg-black shadow mb-5 border-bottom border-warning">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">IRONCORE</a>
        </div>
    </nav>

    <div class="container">
        <div class="row bg-secondary p-4 rounded shadow">
            <div class="col-md-6">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQAmsHlzWluOwV8uw-lJ3asV30yeQROZXn-dw&s" class="img-fluid rounded" alt="Banco">
            </div>
            <div class="col-md-6">
                <h2 class="text-warning">Banco Regulável X-Heavy</h2>
                <h3>R$ 850,00</h3>
                
                <ul class="list-group list-group-flush border rounded mb-4 mt-4">
                    <li class="list-group-item bg-secondary text-white"><strong>Estrutura:</strong> Aço Carbono</li>
                    <li class="list-group-item bg-secondary text-white"><strong>Peso suportado:</strong> 300kg</li>
                    <li class="list-group-item bg-secondary text-white"><strong>Estofado:</strong> Alta densidade</li>
                </ul>

                <form action="/salvar" method="POST" class="mb-4">
                    <input type="hidden" name="produto" value="Banco Regulável X-Heavy">
                    <input type="hidden" name="preco" value="850.00">
                    <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold">SOLICITAR ORÇAMENTO</button>
                </form>

                <div class="accordion" id="ac2">
                    <div class="accordion-item bg-dark text-white">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-dark text-white collapsed" data-bs-toggle="collapse" data-bs-target="#t2">
                                Dimensões
                            </button>
                        </h2>
                        <div id="t2" class="accordion-collapse collapse">
                            <div class="accordion-body">Comprimento: 120cm | Largura: 45cm | Altura: 45cm.</div>
                        </div>
                    </div>
                </div>

                <a href="/produto" class="btn btn-outline-light mt-4 w-100">Voltar para a Loja</a>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>